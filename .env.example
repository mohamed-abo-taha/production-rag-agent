# Copy this file to `.env` and fill in ONE provider key, or export it in your shell.
# Retrieval/ingest work with no key; answering + the eval harness need a provider.

# Provider selection: auto picks groq if GROQ_API_KEY is set, else anthropic.
# LLM_PROVIDER=auto          # auto | groq | anthropic

# --- Option A: Groq (open models like Llama; fast + cheap) ---
GROQ_API_KEY=
# GROQ_ANSWER_MODEL=llama-3.3-70b-versatile
# GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

# --- Option B: Anthropic Claude ---
# ANTHROPIC_API_KEY=
# ANSWER_MODEL=claude-sonnet-4-6
# JUDGE_MODEL=claude-opus-4-8
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Point at a running Qdrant server instead of the local on-disk store:
# QDRANT_URL=http://localhost:6333

# Retrieval tuning
# DENSE_TOP_K=10
# BM25_TOP_K=10
# RERANK_TOP_K=4

# Semantic cache
# CACHE_ENABLED=true
# CACHE_SIMILARITY_THRESHOLD=0.95
